<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Arcade Cabinet App Switcher"
           Language="1033"
           Version="$(InstallerVersion)"
           Manufacturer="Magnus Akselvoll"
           UpgradeCode="{A7E8B5C6-D9F0-4321-8765-12AB34CD56EF}">

    <!--
      MajorUpgrade scheduled afterInstallExecute: new version installs first, then old version
      is removed. This preserves NeverOverwrite components (appsettings.json, profiles.json).
      AllowSameVersionUpgrades: re-running the same MSI version triggers a full upgrade cycle
      instead of maintenance mode, ensuring recovery from interrupted installations.
      REINSTALLMODE=amus: forces file replacement regardless of version stamps during
      reinstall/upgrade. NeverOverwrite components are unaffected (evaluated at CostFinalize).
    -->
    <MajorUpgrade Schedule="afterInstallExecute"
                  AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Arcade Cabinet App Switcher is already installed." />

    <Property Id="REINSTALLMODE" Value="amus" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Complete" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- Minimal UI: welcome dialog, progress bar with step messages, and finish dialog -->
    <UIRef Id="WixUI_Minimal" />

    <UI>
      <ProgressText Action="InstallFiles" Message="Installing application files..." />
      <ProgressText Action="InstallServices" Message="Registering Windows service..." />
      <ProgressText Action="StartServices" Message="Starting Windows service..." />
      <ProgressText Action="StopServices" Message="Stopping Windows service..." />
      <ProgressText Action="DeleteServices" Message="Removing Windows service..." />
      <ProgressText Action="RemoveFiles" Message="Removing old files..." />
      <ProgressText Action="RemoveExistingProducts" Message="Removing previous version..." />
    </UI>

    <!--
      Show installation paths in the finish dialog so operators know where to find files.
      [INSTALLFOLDER] is expanded at runtime to the actual installation directory.
    -->
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALTEXT"
                 Before="ExecuteAction"
                 Sequence="ui"
                 Value="Configuration files: [INSTALLFOLDER]profiles.json, [INSTALLFOLDER]appsettings.json&#xA;Log files: [INSTALLFOLDER]logs\" />

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="ArcadeCabinetSwitcher" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!--
        Main executable with service registration and recovery policy (FR-4.3).
        Recovery: restart after 1st and 2nd failure, reboot after 3rd, reset window = 1 day.
      -->
      <Component Id="MainExecutable">
        <File Source="$(PublishDir)ArcadeCabinetSwitcher.exe" KeyPath="yes" />
        <ServiceInstall Id="ServiceInstall"
                        Name="ArcadeCabinetSwitcher"
                        DisplayName="Arcade Cabinet App Switcher"
                        Description="Launches and switches profiles on an arcade cabinet."
                        Start="auto"
                        Type="ownProcess"
                        Account="LocalSystem"
                        ErrorControl="normal" />
        <ServiceControl Id="ServiceControl"
                        Name="ArcadeCabinetSwitcher"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
        <util:ServiceConfig ServiceName="ArcadeCabinetSwitcher"
                            FirstFailureActionType="restart"
                            SecondFailureActionType="restart"
                            ThirdFailureActionType="reboot"
                            RestartServiceDelayInSeconds="5"
                            ResetPeriodInDays="1" />
      </Component>

      <!-- NeverOverwrite preserves user edits to appsettings.json across upgrades (FR-5.3) -->
      <Component Id="AppSettings" NeverOverwrite="yes">
        <File Source="$(PublishDir)appsettings.json" KeyPath="yes" />
      </Component>

      <!-- NeverOverwrite preserves user-configured profiles.json across upgrades (FR-5.3) -->
      <Component Id="ProfilesConfig" NeverOverwrite="yes">
        <File Source="$(PublishDir)profiles.json" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
