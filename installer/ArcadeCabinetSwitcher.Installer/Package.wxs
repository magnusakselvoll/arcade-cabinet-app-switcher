<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Arcade Cabinet App Switcher"
           Language="1033"
           Version="$(InstallerVersion)"
           Manufacturer="Magnus Akselvoll"
           Scope="perUser"
           UpgradeCode="{B3F2A104-E87D-4C59-9A16-5D0E7C8F3A21}">

    <!--
      MajorUpgrade scheduled afterInstallExecute: new version installs first, then old version
      is removed. This preserves NeverOverwrite components (appsettings.json, profiles.json).
      AllowSameVersionUpgrades: re-running the same MSI version triggers a full upgrade cycle
      instead of maintenance mode, ensuring recovery from interrupted installations.
      REINSTALLMODE=amus: forces file replacement regardless of version stamps during
      reinstall/upgrade. NeverOverwrite components are unaffected (evaluated at CostFinalize).
    -->
    <MajorUpgrade Schedule="afterInstallExecute"
                  AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of Arcade Cabinet App Switcher is already installed." />

    <Property Id="REINSTALLMODE" Value="amus" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Complete" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- Minimal UI: welcome dialog, progress bar with step messages, and finish dialog -->
    <UIRef Id="WixUI_Minimal_$(sys.BUILDARCHSHORT)" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <UI>
      <ProgressText Action="InstallFiles" Message="Installing application files..." />
      <ProgressText Action="StopApplication" Message="Stopping running instance..." />
      <ProgressText Action="CreateScheduledTask" Message="Registering scheduled task..." />
      <ProgressText Action="StartScheduledTask" Message="Starting application..." />
      <ProgressText Action="DeleteScheduledTask" Message="Removing scheduled task..." />
      <ProgressText Action="RemoveFiles" Message="Removing old files..." />
      <ProgressText Action="RemoveExistingProducts" Message="Removing previous version..." />
    </UI>

    <!--
      Show installation paths in the finish dialog so operators know where to find files.
      [INSTALLFOLDER] is expanded at runtime to the actual installation directory.
    -->
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALTEXT"
                 Before="ExecuteAction"
                 Sequence="ui"
                 Value="Configuration files:&#xA;  [INSTALLFOLDER]profiles.json (default)&#xA;  %AppData%\ArcadeCabinetSwitcher\profiles.json (user override, takes priority)&#xA;  [INSTALLFOLDER]appsettings.json&#xA;Log files:&#xA;  [INSTALLFOLDER]logs\" />

    <!--
      Custom actions for Task Scheduler management.
      Each SetProperty sets the CustomActionData (command line) for its paired deferred CA.
      WixQuietExec runs the command from CustomActionData in the installing user's context.
    -->

    <!-- Stop any running instance before upgrade or uninstall (ignore failure — may not be running) -->
    <SetProperty Id="StopApplication"
                 Value="taskkill.exe /IM ArcadeCabinetSwitcher.exe /F"
                 Before="StopApplication"
                 Sequence="execute" />
    <CustomAction Id="StopApplication"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <!--
      Create scheduled task: logon trigger, runs as the current user, restarts on failure.
      [SystemFolder] expands to C:\Windows\System32\ in a 64-bit installer.
      [INSTALLFOLDER] expands to the installation directory (includes trailing backslash).
      Logic is in Create-ScheduledTask.ps1 (installed alongside the exe) to stay within the
      255-character MSI CustomAction.Target column limit (ICE03).
    -->
    <SetProperty Id="CreateScheduledTask"
                 Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]Create-ScheduledTask.ps1&quot; &quot;[INSTALLFOLDER]&quot;"
                 Before="CreateScheduledTask"
                 Sequence="execute" />
    <CustomAction Id="CreateScheduledTask"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />

    <!-- Start the task immediately after installation (ignore failure — may require user session) -->
    <SetProperty Id="StartScheduledTask"
                 Value="schtasks.exe /Run /TN &quot;ArcadeCabinetSwitcher&quot;"
                 Before="StartScheduledTask"
                 Sequence="execute" />
    <CustomAction Id="StartScheduledTask"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <!-- Delete scheduled task on uninstall (ignore failure — task may not exist) -->
    <SetProperty Id="DeleteScheduledTask"
                 Value="schtasks.exe /Delete /TN &quot;ArcadeCabinetSwitcher&quot; /F"
                 Before="DeleteScheduledTask"
                 Sequence="execute" />
    <CustomAction Id="DeleteScheduledTask"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Stop running instance before installing new files (upgrade) or removing (uninstall) -->
      <Custom Action="StopApplication" Before="InstallFiles" Condition="REMOVE=&quot;ALL&quot; OR WIX_UPGRADE_DETECTED" />
      <!-- Create task after files are in place, on install or upgrade -->
      <Custom Action="CreateScheduledTask" After="InstallFiles" Condition="NOT REMOVE" />
      <!-- Start the task immediately; ignore failure if no interactive session is available -->
      <Custom Action="StartScheduledTask" After="CreateScheduledTask" Condition="NOT REMOVE" />
      <!-- Delete task before removing files on full uninstall -->
      <Custom Action="DeleteScheduledTask" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="ArcadeCabinetSwitcher" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!--
        ICE38: Per-user components must use an HKCU registry value as KeyPath (not a file).
        ICE64: One component must have RemoveFolder so the install directory is cleaned up on uninstall.
      -->

      <!-- Main executable -->
      <Component Id="MainExecutable" Guid="{1C6DC335-C5FA-4A78-86F5-B87FD2E61514}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="MainExecutable" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)ArcadeCabinetSwitcher.exe" />
        <RemoveFolder Id="RemoveINSTALLFOLDER" On="uninstall" />
      </Component>

      <!-- NeverOverwrite preserves user edits to appsettings.json across upgrades (FR-5.3) -->
      <Component Id="AppSettings" NeverOverwrite="yes" Guid="{E7A66B08-7460-44A3-B6EC-3CC4CE35BBB8}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="AppSettings" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)appsettings.json" />
      </Component>

      <!-- NeverOverwrite preserves user-configured profiles.json across upgrades (FR-5.3) -->
      <Component Id="ProfilesConfig" NeverOverwrite="yes" Guid="{984456B4-78F8-4BCB-8DDD-F17C3F0341FC}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="ProfilesConfig" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)profiles.json" />
      </Component>

      <!--
        Native libraries required at runtime. When adding a new NuGet dependency that ships native
        binaries, check the win-x64 publish output and add any new *.dll files here, otherwise the
        MSI will install an incomplete package that crashes on startup with DllNotFoundException.
      -->

      <!-- SDL2 native library required by Silk.NET for joystick input -->
      <Component Id="Sdl2Native" Guid="{A592EF0C-3A35-4BBC-BF2D-DE956CCCC207}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="Sdl2Native" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)SDL2.dll" />
      </Component>

      <!-- SkiaSharp native library required by Avalonia rendering backend -->
      <Component Id="SkiaSharpNative" Guid="{C3D4E5F6-A7B8-4901-BCDE-F01234567890}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="SkiaSharpNative" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)libSkiaSharp.dll" />
      </Component>

      <!-- HarfBuzzSharp native library required by Avalonia text rendering -->
      <Component Id="HarfBuzzSharpNative" Guid="{D4E5F6A7-B8C9-4012-CDEF-012345678901}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="HarfBuzzSharpNative" Type="integer" Value="1" KeyPath="yes" />
        <File Source="$(PublishDir)libHarfBuzzSharp.dll" />
      </Component>

      <!-- PowerShell script invoked by CreateScheduledTask custom action (logic extracted to stay within ICE03 255-char limit) -->
      <Component Id="ScheduledTaskScript" Guid="{18B8F2FC-ECB0-4532-A4EF-F3BBEE4FE3B7}">
        <RegistryValue Root="HKCU" Key="Software\ArcadeCabinetSwitcher" Name="ScheduledTaskScript" Type="integer" Value="1" KeyPath="yes" />
        <File Source="Create-ScheduledTask.ps1" />
      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
